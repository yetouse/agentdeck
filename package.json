{
  "name": "agentdeck",
  "version": "0.1.0",
  "private": true,
  "description": "Real-time web cockpit for supervising AI coding agents",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/web",
    "build": "npm run build --workspace=apps/web",
    "typecheck": "npm run typecheck --workspace=apps/web"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yetouse/agentdeck.git"
  },
  "author": "Yannick CAISE <yannick.caise@gmail.com> (https://github.com/yetouse)",
  "license": "MIT",
  "keywords": [
    "ai-agents",
    "developer-tools",
    "dashboard",
    "monitoring",
    "claude-code",
    "observability"
  ]
}
